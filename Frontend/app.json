{
  "expo": {
    "name": "BookLink",
    "slug": "booklink",
    "scheme": "booklink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BookLink to choose a cover photo for your listing.",
          "cameraPermission": "Allow BookLink to take a photo for your book cover."
        }
      ],
      "expo-font"
    ],
    "ios": {
      "bundleIdentifier": "lk.booklink.app",
      "supportsTablet": true
    },
    "android": {
      "package": "lk.booklink.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3e8bb706-2e08-468e-8e00-655c4e481835"
      }
    },
    "owner": "jayashan"
  }
}
